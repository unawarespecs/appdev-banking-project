<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankapp.jfx.controllers.AdminController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Administrator Dashboard" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="nameInput" promptText="Account Holder Name" maxWidth="300"/>
    <TextField fx:id="initialDepositInput" promptText="Initial Deposit Amount" maxWidth="300"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Create Account" onAction="#handleCreateAccount"/>
        <Button text="Modify Account" onAction="#handleModifyAccount"/>
        <Button text="Delete Account" onAction="#handleDeleteAccount"/>
    </HBox>

    <Label fx:id="statusLabel" text="Ready" textFill="blue"/>
</VBox>