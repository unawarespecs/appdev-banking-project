<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_LEFT" spacing="20.0" stylesheets="@/assets/css/fluent-override.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankdb.controllers.DepositController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Button mnemonicParsing="false" onAction="#handleBackToDashboard" style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-cursor: hand; -fx-padding: 0 0 10 0;" text="← Back to Dashboard">
        <font>
            <Font name="System Bold" size="14.0" />
        </font>
    </Button>

    <VBox spacing="5.0">
        <Label text="Deposit Funds" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Label text="Add money securely to your account balance." textFill="#7f8c8d" />
    </VBox>

    <VBox maxWidth="400.0" spacing="8.0">
        <Label text="Amount to Deposit ($)" textFill="#34495e">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>
        <TextField fx:id="depositAmountField" prefHeight="40.0" promptText="0.00" style="-fx-background-radius: 5; -fx-border-radius: 5;" />
    </VBox>

    <Button fx:id="confirmDepositButton" mnemonicParsing="false" onAction="#handleDepositSubmit" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="Confirm Deposit" />

    <Label fx:id="depositStatusLabel" />
</VBox>