<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="450.0" spacing="35.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankdb.controllers.AdminMenuController">
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
    </padding>

    <VBox alignment="CENTER" spacing="10">
        <Label text="Administrator Console" textFill="#2b5797">
            <font><Font name="System Bold" size="28.0" /></font>
        </Label>
        <Label text="Manage system modules and users" textFill="#64748b" />
    </VBox>

    <VBox alignment="CENTER" spacing="20.0" maxWidth="350.0" style="-fx-background-color: #ffffff; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <Button fx:id="accountManagerBtn" maxWidth="Infinity" minHeight="55.0" onAction="#onAccountManagerClick" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Account Manager" />
        <Button fx:id="loanManagerBtn" maxWidth="Infinity" minHeight="55.0" onAction="#onLoanManagerClick" style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Loan Manager" />
        <VBox spacing="10"><padding><Insets top="15"/></padding></VBox>
        <Button fx:id="logoutBtn" maxWidth="Infinity" minHeight="45.0" onAction="#onLogoutButtonClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="Secure Logout" />
    </VBox>
</VBox>