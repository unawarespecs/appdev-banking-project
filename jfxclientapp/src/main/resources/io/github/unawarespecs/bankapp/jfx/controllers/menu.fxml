<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="parentStage" alignment="CENTER" prefHeight="550.0" prefWidth="750.0" spacing="20.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankdb.controllers.MenuController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <BorderPane prefHeight="500.0" prefWidth="700.0" VBox.vgrow="ALWAYS">
        <top>
            <VBox alignment="CENTER_LEFT" spacing="5.0" BorderPane.alignment="CENTER">
                <padding>
                    <Insets bottom="15.0" left="15.0" right="15.0" top="10.0" />
                </padding>
                <Label text="Customer Dashboard" textFill="#2b5797">
                    <font><Font name="System Bold" size="24.0" /></font>
                </Label>
                <Label text="Manage your funds and transactions" textFill="#64748b" />
                <Separator prefWidth="200.0">
                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                </Separator>
            </VBox>
        </top>

        <left>
            <VBox maxWidth="220.0" minWidth="200.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);" BorderPane.alignment="CENTER">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <Button maxWidth="Infinity" onAction="#onDashboardClick" prefHeight="40" style="-fx-alignment: BASELINE_LEFT; -fx-background-color: #e8f0fe; -fx-text-fill: #2b5797; -fx-font-weight: bold;" text="Dashboard Overview" />
                <Button maxWidth="Infinity" onAction="#onTransactionsClick" prefHeight="40" style="-fx-alignment: BASELINE_LEFT;" text="Transaction Ledger" />
                <Button maxWidth="Infinity" onAction="#onTransferClick" prefHeight="40" style="-fx-alignment: BASELINE_LEFT;" text="Transfer Funds" />
                <Button maxWidth="Infinity" onAction="#onSettingsClick" prefHeight="40" style="-fx-alignment: BASELINE_LEFT;" text="Profile Settings" />
                <VBox VBox.vgrow="ALWAYS" />
                <Separator prefWidth="200.0" />
                <Button maxWidth="Infinity" onAction="#onLogoutClick" prefHeight="40" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-alignment: CENTER; -fx-font-weight: bold;" text="Log Out" />
            </VBox>
        </left>

        <center>
            <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);" BorderPane.alignment="CENTER">
                <padding>
                    <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                </padding>
                <BorderPane.margin>
                    <Insets left="20.0" />
                </BorderPane.margin>
                <Label text="Welcome Back!" textFill="#1e293b">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
                <Label text="Select an operation from the left sidebar panel to get started." textFill="#64748b" wrapText="true" style="-fx-font-size: 14px;"/>
            </VBox>
        </center>
    </BorderPane>
</VBox>

<!-- T -->