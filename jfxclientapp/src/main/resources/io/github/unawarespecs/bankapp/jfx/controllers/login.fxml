<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="parentBox" alignment="CENTER" prefHeight="450.0" prefWidth="400.0" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankdb.controllers.LoginController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <BorderPane prefHeight="400.0" prefWidth="340.0" VBox.vgrow="ALWAYS">
        <top>
            <VBox alignment="CENTER" spacing="8.0" BorderPane.alignment="CENTER">
                <padding>
                    <Insets bottom="20.0" />
                </padding>
                <children>
                    <Label text="Bank Label" textFill="#1e293b">
                        <font>
                            <Font name="System Bold" size="24.0" />
                        </font>
                    </Label>
                    <Label text="Sign in to your account" textFill="#64748b">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </Label>
                </children>
            </VBox>
        </top>

        <center>
            <VBox spacing="15.0" BorderPane.alignment="CENTER">
                <children>
                    <VBox spacing="5.0">
                        <children>
                            <Label text="Username" textFill="#475569">
                                <font>
                                    <Font name="System Bold" size="12.0" />
                                </font>
                            </Label>
                            <TextField fx:id="usernameField" prefHeight="38.0" promptText="Enter your username" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1;" />
                        </children>
                    </VBox>

                    <VBox spacing="5.0">
                        <children>
                            <Label text="Password" textFill="#475569">
                                <font>
                                    <Font name="System Bold" size="12.0" />
                                </font>
                            </Label>
                            <PasswordField fx:id="passwordField" prefHeight="38.0" promptText="Enter your password" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1;" />
                        </children>
                    </VBox>
                </children>
                <padding>
                    <Insets top="10.0" />
                </padding>
            </VBox>
        </center>

        <bottom>
            <VBox alignment="CENTER" spacing="15.0" BorderPane.alignment="CENTER">
                <children>
                    <Button maxWidth="Infinity" onAction="#onLoginButtonClick" prefHeight="40.0" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;" text="Log In">
                        <font>
                            <Font name="System Bold" size="14.0" />
                        </font>
                    </Button>
                    <Label fx:id="errorLabel" textAlignment="CENTER" textFill="#ef4444" wrapText="true" />
                </children>
                <padding>
                    <Insets top="20.0" />
                </padding>
            </VBox>
        </bottom>
    </BorderPane>
</VBox>
