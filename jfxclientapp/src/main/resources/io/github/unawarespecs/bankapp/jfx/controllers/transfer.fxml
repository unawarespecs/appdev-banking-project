<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="450.0" spacing="25.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <VBox alignment="CENTER" spacing="10">
        <Label text="Transfer Funds" textFill="#2b5797">
            <font><Font name="System Bold" size="24.0" /></font>
        </Label>
        <Label text="Send money to another account instantly" textFill="#64748b" />
    </VBox>

    <VBox spacing="20.0" style="-fx-background-color: #ffffff; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
        <VBox spacing="5.0">
            <Label text="Recipient Account ID" textFill="#475569">
                <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <TextField fx:id="recipientIdField" prefHeight="40.0" promptText="Enter the 4-digit Account ID" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1;" />
        </VBox>

        <VBox spacing="5.0">
            <Label text="Transfer Amount (₱)" textFill="#475569">
                <font><Font name="System Bold" size="12.0" /></font>
            </Label>
            <TextField fx:id="transferAmountField" prefHeight="40.0" promptText="0.00" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #cbd5e1;" />
        </VBox>

        <Button maxWidth="Infinity" prefHeight="45.0" style="-fx-background-color: #2b5797; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;" text="Confirm Transfer">
            <VBox.margin><Insets top="10.0" /></VBox.margin>
        </Button>
    </VBox>

    <Button text="Cancel and Return to Menu" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-cursor: hand; -fx-underline: true;"/>
</VBox>