<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankdb.controllers.TransferFundsController">

    <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #ffffff; -fx-padding: 40; -fx-background-radius: 10;">
        <Label text="Transfer Funds" textFill="#2b5797">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <TextField fx:id="recipientField" prefHeight="40" promptText="Recipient Account ID" />
        <TextField fx:id="amountField" prefHeight="40" promptText="Amount to Transfer" />
        <Button maxWidth="Infinity" onAction="#onConfirmTransferClick" prefHeight="40" style="-fx-background-color: #2b5797; -fx-text-fill: white;" text="Confirm Transfer" />
    </VBox>

    <VBox fx:id="pinPopupOverlay" alignment="CENTER" spacing="15.0" style="-fx-background-color: rgba(0, 0, 0, 0.5);" visible="false">
        <VBox alignment="CENTER" spacing="15.0" maxWidth="350" style="-fx-background-color: #ffffff; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);">
            <Label text="Security Verification" textFill="#1e293b">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <Label text="Please enter your 4-digit PIN to continue." textFill="#64748b" wrapText="true" textAlignment="CENTER"/>
            <PasswordField fx:id="pinEntryField" promptText="Enter PIN" prefHeight="40" maxWidth="200" alignment="CENTER" style="-fx-font-size: 16px; -fx-letter-spacing: 5px;"/>

            <HBox spacing="10" alignment="CENTER">
                <Button onAction="#onCancelPinClick" text="Cancel" prefWidth="100" prefHeight="40" style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b;" />
                <Button onAction="#onSubmitPinClick" text="Submit" prefWidth="100" prefHeight="40" style="-fx-background-color: #2b5797; -fx-text-fill: white; -fx-font-weight: bold;" />
            </HBox>
        </VBox>
    </VBox>
</StackPane>