<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="30.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankdb.controllers.LoanManagerController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <VBox maxWidth="320.0" minWidth="300.0" spacing="25.0">
        <Button fx:id="backBtn" onAction="#onBackClick" style="-fx-background-color: #e2e8f0; -fx-padding: 8 15;" text="← Back to Menu" />

        <VBox spacing="18.0" style="-fx-background-color: #ffffff; -fx-padding: 25; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <Label text="Set Loan Parameters" textFill="#1e293b">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
         <TextField fx:id="loanNameField" promptText="Loan Name " />
         <Label layoutX="35.0" layoutY="35.0" text="Loan Duration (Months)" textFill="#1e293b">
            <font>
               <Font name="System Bold" size="18.0" />
            </font>
         </Label>
         <Spinner fx:id="loanDurationField" editable="true" prefHeight="26.0" prefWidth="254.0" />
         <Label layoutX="35.0" layoutY="124.0" text="Max Amount (₱)" textFill="#1e293b">
            <font>
               <Font name="System Bold" size="18.0" />
            </font>
         </Label>
         <Spinner fx:id="loanMaxLimitField" editable="true" layoutX="35.0" layoutY="170.0" prefHeight="26.0" prefWidth="254.0" />
         <Label layoutX="35.0" layoutY="124.0" text="Interest Rate" textFill="#1e293b">
            <font>
               <Font name="System Bold" size="18.0" />
            </font>
         </Label>
         <Spinner fx:id="loanInterestField" editable="true" layoutX="35.0" layoutY="170.0" prefHeight="26.0" prefWidth="252.0" />
            <Button fx:id="savePlanBtn" maxWidth="Infinity" onAction="#onSavePlanClick" prefHeight="45" style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-font-weight: bold;" text="Update Active Loan Plan" />
        </VBox>
    </VBox>

    <VBox spacing="20.0" style="-fx-background-color: #ffffff; -fx-padding: 25; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
        <Label text="Accounts with Active Loans" textFill="#2b5797">
            <font><Font name="System Bold" size="22.0" /></font>
        </Label>

        <HBox spacing="15.0">
            <TextField fx:id="searchLoanField" prefHeight="40" promptText="Search active loans..." HBox.hgrow="ALWAYS" />
            <Button fx:id="searchLoanBtn" onAction="#onSearchLoanClick" prefHeight="40" prefWidth="100" style="-fx-background-color: #2b5797; -fx-text-fill: white;" text="Search" />
        </HBox>

        <TableView fx:id="loanAccountsTable" style="-fx-font-size: 14px;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colLoanAccountId" prefWidth="120.0" text="Account ID" />
                <TableColumn fx:id="colLoanAccountName" prefWidth="200.0" text="Account Holder" />
                <TableColumn fx:id="colLoanAmount" prefWidth="150.0" text="Loan Balance" />
                <TableColumn fx:id="colLoanRate" prefWidth="120.0" text="Interest Rate" />
                <TableColumn fx:id="colLoanTerm" prefWidth="140.0" text="Term (Months)" />
            </columns>
        </TableView>
    </VBox>
</HBox>
