<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="30.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankdb.controllers.LoanManagerController">
    <children>
        <VBox maxWidth="350.0" minWidth="280.0" spacing="15.0">
            <children>
                <Button fx:id="backBtn" mnemonicParsing="false" onAction="#onBackClick" text="← " />
                <VBox spacing="12.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;">
                    <children>
                        <Label text="Set Loan Parameters">
                            <font>
                                <Font name="System Bold" size="15.0" />
                            </font>
                        </Label>
                        <TextField fx:id="loanDurationField" promptText="Duration (e.g. 6)" />
                        <TextField fx:id="loanMaxLimitField" promptText="Max Limit ($)" />
                        <TextField fx:id="loanInterestField" promptText="Interest Rate (%)" />
                        <Button fx:id="savePlanBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onSavePlanClick" text="Update Active Loan Plan" />
                    </children>
                </VBox>
            </children>
        </VBox>
        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
            <children>
                <Label text="Accounts with Active Loans">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="searchLoanField" promptText="Search active loans..." HBox.hgrow="ALWAYS" />
                        <Button fx:id="searchLoanBtn" mnemonicParsing="false" onAction="#onSearchLoanClick" text="Search" />
                    </children>
                </HBox>
                <TableView fx:id="loanAccountsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colLoanAccountId" prefWidth="100.0" text="Account ID" />
                        <TableColumn fx:id="colLoanAccountName" prefWidth="180.0" text="Account Holder" />
                        <TableColumn fx:id="colLoanAmount" prefWidth="120.0" text="Loan Balance" />
                        <TableColumn fx:id="colLoanRate" prefWidth="90.0" text="Interest Rate" />
                        <TableColumn fx:id="colLoanTerm" prefWidth="110.0" text="Term (Months)" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</HBox>
