<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="30.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankdb.controllers.AccountManagerController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <VBox spacing="20.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Button fx:id="backBtn" onAction="#onBackClick" text="← Back" style="-fx-background-color: #e2e8f0;"/>
            <Label text="Account Directory" textFill="#2b5797">
                <font><Font name="System Bold" size="22.0" /></font>
            </Label>
        </HBox>

        <HBox spacing="15.0">
            <TextField fx:id="searchField" promptText="Search by Account ID or Name..." HBox.hgrow="ALWAYS" prefHeight="40"/>
            <Button fx:id="searchBtn" onAction="#onSearchClick" text="Search" prefHeight="40" prefWidth="100" style="-fx-background-color: #2b5797; -fx-text-fill: white;"/>
        </HBox>

        <TableView fx:id="accountTable" editable="true" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px;">
            <columns>
                <TableColumn fx:id="colId" prefWidth="90.0" text="Account ID" />
                <TableColumn fx:id="colName" prefWidth="200.0" text="Name" />
                <TableColumn fx:id="colRole" prefWidth="120.0" text="Role" />
                <TableColumn fx:id="colBalance" prefWidth="150.0" text="Balance" />
                <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
            </columns>
        </TableView>
    </VBox>

    <VBox maxWidth="350.0" minWidth="320.0" spacing="25.0">
        <VBox spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 25; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <Label text="Create New Account" textFill="#1e293b">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <TextField fx:id="createNameField" promptText="Name of User" prefHeight="40"/>
            <TextField fx:id="createPasswordField" promptText="Password of User" prefHeight="40"/>
            <ComboBox fx:id="createRoleBox" maxWidth="Infinity" promptText="Select Role" prefHeight="40"/>
            <Button fx:id="createBtn" maxWidth="Infinity" onAction="#onCreateClick" prefHeight="45" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Register Account" />
        </VBox>

        <HBox fx:id="actionStrip" alignment="CENTER" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <Button fx:id="saveDetailsBtn" onAction="#onSaveDetailsClick" prefWidth="140.0" prefHeight="40" style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-font-weight: bold;" text="Save Changes" />
            <Button fx:id="deleteBtn" onAction="#onDeleteClick" prefWidth="140.0" prefHeight="40" style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-font-weight: bold;" text="Delete Selected" />
        </HBox>

    </VBox>
</HBox>