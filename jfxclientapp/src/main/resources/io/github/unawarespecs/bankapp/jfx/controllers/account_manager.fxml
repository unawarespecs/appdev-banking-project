<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="30.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankdb.controllers.AccountManagerController">
    <children>
        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Button fx:id="backBtn" mnemonicParsing="false" onAction="#onBackClick" text="← Back" />
                        <Label text="Account Directory">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <TextField fx:id="searchField" promptText="Search by Account ID or Name..." HBox.hgrow="ALWAYS" />
                        <Button fx:id="searchBtn" mnemonicParsing="false" onAction="#onSearchClick" text="Search" />
                    </children>
                </HBox>
                <TableView fx:id="accountTable" editable="true" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="75.0" text="Account ID" />
                        <TableColumn fx:id="colName" prefWidth="150.0" text="Name" />
                        <TableColumn fx:id="colRole" prefWidth="100.0" text="Role" />
                        <TableColumn fx:id="colBalance" prefWidth="100.0" text="Balance" />
                        <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                    </columns>
                </TableView>
            </children>
        </VBox>
        <VBox maxWidth="350.0" minWidth="300.0" spacing="20.0">
            <children>
                <VBox spacing="15.0" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;">
                    <children>
                        <Label text="Create Account">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <TextField fx:id="createNameField" promptText="Name of User" />
                        <TextField fx:id="createPasswordField" promptText="Password of User" />
                        <ComboBox fx:id="createRoleBox" maxWidth="1.7976931348623157E308" promptText="Select Role" />
                        <Button fx:id="createBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCreateClick" styleClass="accent" text="Register Account" />
                    </children>
                </VBox>

                <HBox fx:id="actionStrip" alignment="CENTER_RIGHT" spacing="15.0" style="-fx-background-color: #f9f9f9; -fx-padding: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 4; -fx-background-radius: 4;">
               <children>
                        <Button fx:id="saveDetailsBtn" mnemonicParsing="false" onAction="#onSaveDetailsClick" prefWidth="140.0" text="Save Changes" />
                        <Button fx:id="deleteBtn" mnemonicParsing="false" onAction="#onDeleteClick" prefWidth="140.0" style="-fx-background-color: #d9534f; -fx-text-fill: white;" text="Delete Selected" />
               </children>
                </HBox>
            </children>
        </VBox>
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</HBox>
